rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // By default, a user can only read/write documents that belong to their businessId
    match /{document=**} {
      allow read, write: if isAuthenticated() && resource.data.businessId == request.auth.uid;
    }

    // Allow creating new documents if they set the businessId to their own uid
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    match /inventory/{itemId} {
      allow create: if isAuthenticated() && request.resource.data.businessId == request.auth.uid;
      allow read, update, delete: if isAuthenticated() && resource.data.businessId == request.auth.uid;
    }

    match /inventoryLogs/{logId} {
      allow create: if isAuthenticated() && request.resource.data.businessId == request.auth.uid;
      allow read, update, delete: if isAuthenticated() && resource.data.businessId == request.auth.uid;
    }

    match /invoices/{invoiceId} {
      allow create: if isAuthenticated() && request.resource.data.businessId == request.auth.uid;
      allow read, update, delete: if isAuthenticated() && resource.data.businessId == request.auth.uid;
    }

    match /parties/{partyId} {
      allow create: if isAuthenticated() && request.resource.data.businessId == request.auth.uid;
      allow read, update, delete: if isAuthenticated() && resource.data.businessId == request.auth.uid;
    }

    match /settings/{settingId} {
      allow create: if isAuthenticated() && request.resource.data.businessId == request.auth.uid;
      allow read, update, delete: if isAuthenticated() && resource.data.businessId == request.auth.uid;
    }

    match /staff/{staffId} {
      allow create: if isAuthenticated() && request.resource.data.businessId == request.auth.uid;
      allow read, update, delete: if isAuthenticated() && resource.data.businessId == request.auth.uid;
    }
  }
}
